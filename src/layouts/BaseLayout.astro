---
import "../styles/global.scss";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Rubén Terré - Desarrollo web, diseño gráfico y docencia</title>

    <!-- Favicons (set mínimo y moderno) -->
    <link
      rel="icon"
      href="/favicon/favicon_32x32@1x.png"
      sizes="32x32"
      type="image/png"
    />
    <link rel="apple-touch-icon" href="/favicon/favicon_180x180@1x.png" />
    <link
      rel="icon"
      href="/favicon/favicon_192x192@1x.png"
      sizes="192x192"
      type="image/png"
    />
    <link
      rel="icon"
      href="/favicon/favicon_512x512@1x.png"
      sizes="512x512"
      type="image/png"
    />

    <meta
      name="description"
      content="Páxina de portfolio de Rubén Terré, diseñador gráfico, desarrollador web y docente."
    />
    <meta name="author" content="Rubén Arturo Terré Lameiro" />

    <!-- Open Graph -->
    <meta
      property="og:title"
      content="Rubén Terré. Diseñador gráfico, desarrollador web y docente"
    />
    <meta
      property="og:description"
      content="Este es el portfolio de Rubén Terré, en el que encontraréis su curriculum vitae y una muestra de sus habilidades, experiencia y formaciones."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://rubenterre.com" />
    <meta
      property="og:image"
      content="https://rubenterre.com/rubenterre__OGraph.jpeg"
    />
    <meta
      property="og:site_name"
      content="Rubén Terre - Diseñador gráfico, desarrollador web y docente"
    />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Rubén Terre - Diseñador gráfico, desarrollador web y docente"
    />
    <meta
      name="twitter:description"
      content="Este es el portfolio de Rubén Terré, en el que encontraréis su curriculum vitae y una muestra de sus habilidades, experiencia y formaciones."
    />
    <meta
      name="twitter:image"
      content="https://rubenterre.com/rubenterre__OGraph.jpeg"
    />
    <meta name="twitter:site" content="@RubenTerre" />

    <link rel="canonical" href="https://rubenterre.com" />
    <meta name="theme-color" content="#0D0D0D" />
  </head>
  <body>
    <slot name="header" />
    <main id="main-content">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
